      "requiredVersion": "0.0.1",
      "version": "1.0.1",
      "author": "𝙈𝙖𝙠𝙠𝙖𝙋𝙖𝙠𝙠𝙖",
      "url": "https://raw.githubusercontent.com/MakkaPakka518/FW/refs/heads/main/widgets/normal/redu.js"
    },
    {
      "id": "zhuijurili",
      "title": "追剧日历",
